# Strapi backend
NEXT_PUBLIC_STRAPI_URL=https://cms.fxnstudio.com
STRAPI_API_TOKEN=

# Public site URL (used for canonicals, sitemap, RSS, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://nxtbargains.fxnstudio.com

# Default Amazon Associates tag — appended to amzn.to / amazon.* links missing a tag
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=

# RapidAPI coupon feeds (server-side only)
RAPIDAPI_KEY=
RAPIDAPI_PROMO_CODES_HOST=get-promo-codes.p.rapidapi.com
RAPIDAPI_PROMO_CODES_PATH=/data/get-coupons/?page=1&sort=update_time_desc
RAPIDAPI_PROMO_STORES_PATH=/data/get-stores/?page=1
RAPIDAPI_POPULAR_COUPON_BRANDS=amazon,ebay,walmart,newegg
RAPIDAPI_AMAZON_DEALS_HOST=amazon-promo-codes-and-deals.p.rapidapi.com
RAPIDAPI_AMAZON_DEALS_KEY=
RAPIDAPI_AMAZON_DEALS_PATH=/deals.php?limit=20&offset=0&min_discount=50&max_discount=90&channel=1&category=Apparel&merchant=Amazon&condition=New&coupon_only=1&promo_only=1&since=2026-03-26&dual_offer=1

# Private research access for /coupons/stores
COUPON_STORES_ADMIN_TOKEN=
